APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Admin subdomain
# Example: ADMIN_DOMAIN=admin.acispedia.com
# Allowed admin emails (comma separated): ADMIN_EMAILS="admin@acispedia.com,owner@acispedia.com"
ADMIN_DOMAIN=
ADMIN_EMAILS=

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Reverb (WebSockets) - used for realtime order status updates
REVERB_APP_ID=local
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MEDANPEDIA_BASE_URL=https://api.medanpedia.co.id
MEDANPEDIA_API_ID=
MEDANPEDIA_API_KEY=
MEDANPEDIA_TIMEOUT=20
MEDANPEDIA_FORCE_IPV4=false
MEDANPEDIA_AUTO_IPV4_FALLBACK=true
MEDANPEDIA_SERVICES_CACHE_TTL=300
MEDANPEDIA_MARKUP_AMOUNT=200

# Tripay (Deposit) - sandbox by default
TRIPAY_ENABLED=false
TRIPAY_ENV=sandbox
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_DEFAULT_METHOD=QRIS2
TRIPAY_TIMEOUT=30
TRIPAY_CALLBACK_URL=
TRIPAY_RETURN_URL=

# Midtrans (Deposit) - redirect checkout by default
MIDTRANS_ENABLED=false
MIDTRANS_ENV=sandbox
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ADMIN_FEE=4000
MIDTRANS_TIMEOUT=30
MIDTRANS_FINISH_URL=
MIDTRANS_UNFINISH_URL=
MIDTRANS_ERROR_URL=

# Mailketing (Send Email via API)
MAILKETING_BASE_URL=https://api.mailketing.co.id
MAILKETING_API_TOKEN=
MAILKETING_FROM_NAME=
MAILKETING_FROM_EMAIL=

# Telegram notifications (Konversi Saldo)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_TIMEOUT=10
