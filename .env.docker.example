# Copy to .env on the VPS (do NOT commit .env)

APP_NAME=ACISPedia
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://domainkamu.com

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Database (recommended for production)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=acispedia
DB_USERNAME=acispedia
DB_PASSWORD=ubah_password_ini
DB_ROOT_PASSWORD=ubah_root_password_ini

# If you keep these as 'database', MySQL is strongly recommended in production
SESSION_DRIVER=database
QUEUE_CONNECTION=database
CACHE_STORE=database

# Broadcasting / Reverb (server-side: internal Docker network)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=local
REVERB_APP_KEY=local
REVERB_APP_SECRET=local
REVERB_HOST=reverb
REVERB_PORT=8080
REVERB_SCHEME=http

# Vite (client-side/public): should point to your HTTPS domain
VITE_REVERB_APP_KEY=${REVERB_APP_KEY}
VITE_REVERB_HOST=domainkamu.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# Tripay (fill with your production keys)
TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_SANDBOX=false
